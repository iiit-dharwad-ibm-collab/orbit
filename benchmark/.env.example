# Credentials for llm_agent.py. Copy to `.env` and fill in.
# Only the variables for the provider(s) you use are required.

# --- RITS (IBM Research Inference) ---
RITS_API_KEY=

# --- IBM watsonx.ai ---
WATSONX_APIKEY=
WATSONX_PROJECT_ID=
# WATSONX_URL=https://us-south.ml.cloud.ibm.com
# WATSONX_MAX_NEW_TOKENS=8192

# --- OpenAI (or OpenAI-compatible) ---
OPENAI_API_KEY=
OPENAI_MODEL_ID=
# OPENAI_API_BASE=
# OPENAI_MAX_NEW_TOKENS=2048

# --- Anthropic ---
ANTHROPIC_API_KEY=
# ANTHROPIC_MAX_NEW_TOKENS=4096

# --- LiteLLM proxy / generic OpenAI-compatible gateway ---
LITELLM_API_KEY=
LITELLM_BASE_URL=
# LITELLM_MAX_NEW_TOKENS=10000

# --- Optional: response cache location ---
# LLM_AGENT_CACHE=./data/cache/llm_agent_cache.db
